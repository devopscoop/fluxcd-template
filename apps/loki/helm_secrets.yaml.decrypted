# No secret Helm values: S3 access is via IRSA (see serviceAccount.annotations
# in values.yaml), so there are no static credentials to store here.
#
# Static-key alternative — if you don't use IRSA, uncomment and fill these,
# then encrypt with ./encrypt_secrets.sh:
# loki:
#   storage:
#     s3:
#       accessKeyId: CHANGEME-access-key-id
#       secretAccessKey: CHANGEME-secret-access-key
{}
