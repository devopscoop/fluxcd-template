# Secret Helm values, merged on top of values.yaml by the Flux HelmRelease.
# Keep ONLY sensitive object-storage credentials here. Non-secret settings
# (bucket names, endpoint, region) live in values.yaml.
#
# After replacing the placeholders, encrypt with: ./encrypt_secrets.sh
loki:
  storage:
    s3:
      accessKeyId: CHANGEME-access-key-id
      secretAccessKey: CHANGEME-secret-access-key
